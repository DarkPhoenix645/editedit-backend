{
  "info": {
    "_postman_id": "forensiq-backend-v1",
    "name": "ForensIQ Backend",
    "description": "All `/api/*` routes. Use **LOCAL** or **PROD** Postman environment (`HOST_URL`). Vars: `accessToken` + `refreshToken` from Login/Register/Refresh, `logstashSecret` for Logstash-authenticated routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "logstashSecret", "value": "change-me" },
    { "key": "userEmail", "value": "demo@example.com" },
    { "key": "userPassword", "value": "TestPass1a" },
    { "key": "userName", "value": "Demo User" },
    { "key": "userId", "value": "00000000-0000-0000-0000-000000000001" },
    { "key": "orgId", "value": "00000000-0000-0000-0000-000000000010" },
    { "key": "orgSlug", "value": "demo-org" },
    { "key": "blockId", "value": "00000000-0000-0000-0000-000000000001" },
    { "key": "hypothesisId", "value": "00000000-0000-0000-0000-000000000002" },
    { "key": "graphNode", "value": "10.0.0.1" },
    { "key": "eventFingerprint", "value": "sample-fingerprint-sha256" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const host = pm.environment.get(\"HOST_URL\");",
          "if (!host) {",
          "    console.warn(\"Select LOCAL or PROD environment (HOST_URL).\");",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{HOST_URL}}/api/auth/register",
              "host": ["{{HOST_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"name\": \"{{userName}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    try {",
                  "        const j = pm.response.json();",
                  "        if (j.access_token) pm.collectionVariables.set(\"accessToken\", j.access_token);",
                  "        if (j.refresh_token) pm.collectionVariables.set(\"refreshToken\", j.refresh_token);",
                  "    } catch (e) {}",
                  "}",
                  "pm.test(\"2xx\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{HOST_URL}}/api/auth/login",
              "host": ["{{HOST_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{userEmail}}", "type": "text" },
                { "key": "password", "value": "{{userPassword}}", "type": "text" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    try {",
                  "        const j = pm.response.json();",
                  "        if (j.access_token) pm.collectionVariables.set(\"accessToken\", j.access_token);",
                  "        if (j.refresh_token) pm.collectionVariables.set(\"refreshToken\", j.refresh_token);",
                  "    } catch (e) {}",
                  "}",
                  "pm.test(\"2xx\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{HOST_URL}}/api/auth/refresh",
              "host": ["{{HOST_URL}}"],
              "path": ["api", "auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    try {",
                  "        const j = pm.response.json();",
                  "        if (j.access_token) pm.collectionVariables.set(\"accessToken\", j.access_token);",
                  "        if (j.refresh_token) pm.collectionVariables.set(\"refreshToken\", j.refresh_token);",
                  "    } catch (e) {}",
                  "}",
                  "pm.test(\"2xx\", function () { pm.expect(pm.response.code).to.eql(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
