# --- Postgres (docker-compose `db` service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=editedit-db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy / Alembic (host `db` matches the compose service name)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/editedit-db

# --- HTTP server (uvicorn) ---
HOST=0.0.0.0
PORT=8000

# --- Auth / JWT (app.core.config Settings) ---
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
# Base URL for password-reset links in emails (no trailing slash)
FRONTEND_RESET_PASSWORD_URL=

# Optional SMTP — if SMTP_HOST is empty, reset links are only logged (dev-safe).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- Logstash ingest shared secret (X-Logstash-Secret) ---
LOGSTASH_SHARED_SECRET=replace-with-random-secret

# --- S3 / MinIO: single boto3 client for WORM JSONL + cold sealed JSON ---
# Hot-path blocks & WORM reads/writes use WORM_BUCKET; cold JSON uses MINIO_BUCKET on the same endpoint.
WORM_PROVIDER=minio
WORM_ENDPOINT=http://minio:9000
WORM_BUCKET=forensiq-cold-dev
WORM_ACCESS_KEY=minioadmin
WORM_SECRET_KEY=minioadmin
WORM_REGION=us-east-1
WORM_VERIFY_SSL=false
WORM_RETENTION_DAYS=7

# --- Sealing (hot-path) ---
SEALING_SIGNING_KEY_ID=forensiq-local-key
SEALING_PRIVATE_KEY_PEM=
LOGSTASH_CONFIG_VERSION=v2.1.0

# --- Elasticsearch (OCSF / ML paths) ---
ES_URL=https://es01:9200
ES_USER=elastic
ES_PASSWORD=
ES_CA_CERT_PATH=/usr/share/logstash/config/certs/ca/ca.crt
OCSF_INDEX_PATTERN=ocsf-logs-*

# --- Cold-stack signing (sealed blocks / Merkle) ---
COLDSTACK_SIGNING_PRIVATE_KEY_B64=
COLDSTACK_SIGNING_KEY_ID=cold-stack-dev
COLDSTACK_TIMESTAMP_AUTHORITY=backend-local
COLDSTACK_MAX_CLOCK_SKEW_MS=500

# --- Cold sealed JSON objects (same MinIO as WORM_*; separate bucket / prefix / retention) ---
# Set true once to delete/recreate WORM_BUCKET with object lock (minio-init).
MINIO_WORM_RECREATE_BUCKET=false
MINIO_BUCKET=cold-blocks
MINIO_PREFIX=sealed-blocks
MINIO_RETENTION_MODE=COMPLIANCE
MINIO_RETENTION_DAYS=3650
MINIO_AUTO_CREATE_BUCKET=true

# --- ML / anomaly (optional) ---
# ANOMALY_MODEL_PATH=
# ANOMALY_WARMUP_THRESHOLD=500
# RAG_RECOVERY_BATCH_SIZE=1000
AFTER_HOURS_START_HOUR=19
AFTER_HOURS_END_HOUR=7

CORS_ORIGINS=http://localhost:5173