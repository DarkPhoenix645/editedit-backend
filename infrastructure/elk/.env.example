# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=changeme

# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=changeme

# Version of Elastic Stack to use
STACK_VERSION=9.3.1

# License to use (basic, trial, or platinum)
LICENSE=basic

# Ports to expose to the host
ES_PORT=9200
KIBANA_PORT=5601
LOGSTASH_PORT=5044
LOGSTASH_MONITORING_PORT=9600
# Fleet Server HTTPS (host:container); required for docker compose port mapping
FLEET_PORT=8220

# Cold-path backend endpoint reached by Logstash.
COLD_BACKEND_URL=your-cold-backend-url

# A random 32-character string for Kibana encryption
ENCRYPTION_KEY=replace-with-32-char-random-string

# Shared secret used by Logstash cold HTTP output -> backend /api/cold/ingest
LOGSTASH_SHARED_SECRET=replace-with-random-secret

# API key for Logstash elasticsearch output (Fleet integration data streams). Create in Kibana:
# Fleet → Settings → Outputs → your Logstash output → Additional steps → Generate API key
LOGSTASH_FLEET_API_KEY=

# Hot-path retention in days for ocsf-logs-*
OCSF_HOT_RETENTION_DAYS=7
