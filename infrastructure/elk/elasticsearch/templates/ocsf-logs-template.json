{
  "index_patterns": [
    "ocsf-logs-*"
  ],
  "template": {
    "settings": {
      "index.lifecycle.name": "ocsf-logs-7d",
      "index.number_of_shards": 1,
      "index.number_of_replicas": 0
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "message": {
          "type": "text"
        },
        "dataset": {
          "type": "keyword"
        },
        "event_id": {
          "type": "keyword"
        },
        "event": {
          "properties": {
            "id": {
              "type": "keyword"
            },
            "hash": {
              "type": "keyword"
            },
            "dataset": {
              "type": "keyword"
            },
            "outcome": {
              "type": "keyword"
            }
          }
        },
        "forensiq": {
          "properties": {
            "event_fingerprint": {
              "type": "keyword"
            },
            "trust_tier": {
              "type": "keyword"
            }
          }
        },
        "ocsf": {
          "properties": {
            "activity_id": {
              "type": "integer"
            },
            "activity_name": {
              "type": "keyword"
            },
            "category_uid": {
              "type": "integer"
            },
            "category_name": {
              "type": "keyword"
            },
            "class_uid": {
              "type": "integer"
            },
            "class_name": {
              "type": "keyword"
            },
            "severity_id": {
              "type": "integer"
            },
            "severity": {
              "type": "keyword"
            },
            "type_uid": {
              "type": "integer"
            },
            "type_name": {
              "type": "keyword"
            },
            "status": {
              "type": "keyword"
            },
            "status_id": {
              "type": "integer"
            },
            "message": {
              "type": "text"
            },
            "time": {
              "type": "date"
            },
            "src_endpoint": {
              "properties": {
                "ip": {
                  "type": "ip",
                  "ignore_malformed": true
                }
              }
            },
            "dst_endpoint": {
              "properties": {
                "ip": {
                  "type": "ip",
                  "ignore_malformed": true
                }
              }
            },
            "user": {
              "properties": {
                "name": {
                  "type": "keyword"
                }
              }
            },
            "metadata": {
              "properties": {
                "version": {
                  "type": "keyword"
                },
                "uid": {
                  "type": "keyword"
                },
                "product": {
                  "properties": {
                    "name": {
                      "type": "keyword"
                    }
                  }
                }
              }
            }
          }
        },
        "ml": {
          "properties": {
            "source_ip": {
              "type": "ip",
              "ignore_malformed": true
            },
            "dest_ip": {
              "type": "ip",
              "ignore_malformed": true
            },
            "user_id": {
              "type": "keyword"
            },
            "action": {
              "type": "keyword"
            },
            "outcome": {
              "type": "keyword"
            },
            "resource": {
              "type": "keyword"
            },
            "metadata": {
              "properties": {
                "source_type": {
                  "type": "keyword"
                }
              }
            }
          }
        }
      }
    }
  },
  "priority": 500
}
